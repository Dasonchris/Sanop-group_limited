# Session Secret for encrypted session tokens
SESSION_SECRET=

# PostgreSQL Database Connection URL (e.g. for Neon, Google Cloud SQL, etc.)
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=

# Supabase database config (e.g., https://xyz.supabase.co)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
