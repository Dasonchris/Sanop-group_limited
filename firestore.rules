rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Identify system synchronizer with absolute authority over backend tables
    function isSystemSync() {
      return isSignedIn() && request.auth.token.email == "system-sync@sanop.group";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // 👤 USERS COLLECTION
    match /users/{userId} {
      allow read, write: if isSystemSync();
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && (
        request.resource.data.keys().hasAll(['id', 'email', 'fullName', 'phone', 'role', 'isVerified', 'region', 'createdAt', 'updatedAt']) &&
        request.resource.data.keys().size() == 9 &&
        request.resource.data.role == 'user' &&
        request.resource.data.isVerified == false
      );
      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullName', 'phone', 'region', 'updatedAt'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // 📋 ORDERS COLLECTION
    match /orders/{orderId} {
      allow read, write: if isSystemSync();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    // 🔬 CONSULTATIONS COLLECTION
    match /consultations/{consultationId} {
      allow read, write: if isSystemSync();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || request.resource.data.userId == null
      );
      allow update, delete: if isAdmin();
    }

    // 🛡️ LOGS COLLECTION
    match /logs/{logId} {
      allow read, write: if isSystemSync();
      allow read: if isAdmin();
      allow create: if true; // Publicly allow logging of auth failures/activities (securely sanitized)
      allow update, delete: if false;
    }
  }
}
